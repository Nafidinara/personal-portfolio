# Ask Alfara chat — server-only secrets. Never prefix with NEXT_PUBLIC_.
# Copy to .env.local for dev.

# LLM provider (OpenAI-compatible). Default: OpenRouter.
# Swap provider by changing these three — no code change.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=anthropic/claude-haiku-4.5

# Upstash Redis for rate limiting. Leave blank in local dev (limiter becomes a no-op).
# REQUIRED in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
